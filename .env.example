# Production environment for the Drupal backend (Docker Compose on the VM).
# Copy to `.env` on the server and fill in real values. NEVER commit `.env`.

# Public hostname. Caddy issues HTTPS for this automatically. Use a real domain
# (A record -> VM IP) OR, with no domain, an <ip>.nip.io host, e.g.
# 203-0-113-5.nip.io (free, resolves to that IP, still gets a real certificate).
SITE_DOMAIN=api.example.com

# Database (used by both the db service and Drupal).
DB_NAME=newsline
DB_USER=newsline
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-stronger
DB_HOST=db
DB_PORT=3306

# Drupal hash salt — generate once, e.g. `openssl rand -hex 32`.
DRUPAL_HASH_SALT=

# On-demand revalidation: the Vercel frontend's webhook + shared secret
# (must match the frontend's REVALIDATE_SECRET). Leave blank to disable.
REVALIDATE_ENDPOINT=
REVALIDATE_SECRET=
