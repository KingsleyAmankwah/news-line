# Base URL of the Drupal backend (no trailing slash).
# Local DDEV runs on a mapped port; production points at the Oracle host.
DRUPAL_BASE_URL=http://news-line.ddev.site:33000

# OAuth2 client-credentials client. Create a Consumer in Drupal
# (/admin/config/services/consumer) and copy its credentials here.
# These are server-only secrets and must never be exposed to the browser.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Space-separated scopes: the feed list and single-article read.
OAUTH_SCOPE=article_feed:read article:read

# ISR revalidation window for the feed, in seconds.
FEED_REVALIDATE_SECONDS=60
